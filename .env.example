# Subpath deployment (GitHub Pages or Cloudflare Pages at /resume)
# Cloudflare Pages sets CF_PAGES=1 automatically during builds.
GITHUB_PAGES=true
# BASE_PATH=/resume/
# WORKER_SUBPATH=true  # set by deploy:subpath for dy.tsou.me/resume worker layout

# Google Drive resume link
# Your Google Drive share link for the resume download button
VITE_GOOGLE_DRIVE_RESUME_LINK=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing